SNXMCP_SERVER_ADDRESS=:8096
SNXMCP_SERVER_NAME=synthetix-mcp
SNXMCP_SERVER_VERSION=0.1.0
SNXMCP_ENVIRONMENT=development
SNXMCP_LOG_LEVEL=info
SNXMCP_LOG_OUTPUT_JSON=false

# Public Synthetix API endpoint. REST and WebSocket both derive from this.
# Point to api.synthetix.io in prod, http://localhost:8080 when running
# `go run` against a local api-gateway, or http://api-gateway:8080 inside
# the docker compose network.
SNXMCP_API_BASE_URL=https://api.synthetix.io
SNXMCP_API_HTTP_TIMEOUT=10s
SNXMCP_API_MARKET_CACHE_TTL=30s

SNXMCP_EIP712_DOMAIN_NAME=Synthetix
SNXMCP_EIP712_DOMAIN_VERSION=1
SNXMCP_EIP712_CHAIN_ID=1
SNXMCP_AUTH_CACHE_MAX_ENTRIES=50000

SNXMCP_SESSION_TTL=30m
SNXMCP_RISK_SNAPSHOT_MAX_AGE=3m
SNXMCP_MAX_REQUEST_BODY_BYTES=1048576
SNXMCP_MAX_SUBSCRIPTIONS_PER_SESSION=25
# Rate limiting is in-memory; no external store required.
SNXMCP_RATELIMITING_IP_RATE_LIMIT=10000
SNXMCP_RATELIMITING_WINDOW_MS=10000
SNXMCP_RATELIMITING_GENERAL_RATE_LIMIT=1000
SNXMCP_RATELIMITING_SPECIFIC_RATE_LIMITS=123456=230,123457=240,1999989951709581312=1000,1999989938975674368=160
SNXMCP_TRUSTED_PROXY_CIDRS=
# Per-subaccount handler token costs. These bill against the authenticated
# tenant's bucket, so all values are flat per-tool work estimates.
SNXMCP_RATELIMITING_HANDLER_TOKEN_COSTS=authenticate=20,cancel_all_orders=2,cancel_order=2,close_position=5,get_account_summary=30,get_candles=200,get_context=100,get_funding_payments=100,get_funding_rate=250,get_market_summary=100,get_open_orders=10,get_order_history=50,get_orderbook=200,get_performance_history=100,get_positions=10,get_prompt=5,get_rate_limits=20,get_recent_trades=200,get_server_info=5,get_session=5,get_trade_history=50,initialize=1,list_markets=50,list_prompts=5,list_resource_templates=5,list_resources=5,list_tools=5,lookup_subaccount=30,mcp_ping=1,modify_order=5,ping=1,place_order=5,preview_auth_message=5,preview_order=2,preview_trade_signature=2,quick_cancel_all_orders=5,quick_cancel_order=5,quick_close_position=10,quick_place_order=10,read_agent_guide=5,read_fee_schedule=20,read_market_specs=100,read_risk_limits=20,read_runbooks=5,read_server_info=5,read_status=5,restore_session=5,set_guardrails=5,subscribe=10,unsubscribe=5
# Per-IP handler token costs. Mirrors the per-subaccount map except for the
# unauthenticated boundary handlers (authenticate, preview_auth_message) and
# the broker-driven quick_* tools (which transparently authenticate on a
# cold session), all of which are deliberately up-weighted to blunt
# single-IP auth-spray. These values must match defaultIPHandlerTokenCosts()
# in services/mcp/internal/config/config.go -- config_test.go locks them in.
SNXMCP_RATELIMITING_IP_HANDLER_TOKEN_COSTS=authenticate=100,cancel_all_orders=2,cancel_order=2,close_position=5,get_account_summary=30,get_candles=200,get_context=100,get_funding_payments=100,get_funding_rate=250,get_market_summary=100,get_open_orders=10,get_order_history=50,get_orderbook=200,get_performance_history=100,get_positions=10,get_prompt=5,get_rate_limits=20,get_recent_trades=200,get_server_info=5,get_session=5,get_trade_history=50,initialize=1,list_markets=50,list_prompts=5,list_resource_templates=5,list_resources=5,list_tools=5,lookup_subaccount=30,mcp_ping=1,modify_order=5,ping=1,place_order=5,preview_auth_message=10,preview_order=2,preview_trade_signature=2,quick_cancel_all_orders=100,quick_cancel_order=100,quick_close_position=100,quick_place_order=100,read_agent_guide=5,read_fee_schedule=20,read_market_specs=100,read_risk_limits=20,read_runbooks=5,read_server_info=5,read_status=5,restore_session=5,set_guardrails=5,subscribe=10,unsubscribe=5

# --- Agent Broker (optional, single-tenant local mode) ---
# When enabled, the MCP server holds the agent's private key in process
# memory and exposes `quick_*` tools that auto-authenticate and auto-sign
# trade actions on the agent's behalf. Designed for local laptop usage
# (Claude Desktop, Cursor) where the LLM cannot itself perform EIP-712
# signing. Refuses to start unless the server binds to loopback unless
# AGENT_BROKER_ALLOW_NON_LOOPBACK is also true.
SNXMCP_AGENT_BROKER_ENABLED=false
# Only one of HEX or FILE may be set.
SNXMCP_AGENT_BROKER_PRIVATE_KEY_HEX=
SNXMCP_AGENT_BROKER_PRIVATE_KEY_FILE=
# Optional: pre-bind a specific subaccount. If unset, the broker
# auto-discovers the first owned subaccount on first authenticate.
SNXMCP_AGENT_BROKER_SUB_ACCOUNT_ID=
# Default guardrails applied on the auto-authenticated session if the
# agent has not explicitly set them yet. Comma-separated lists.
SNXMCP_AGENT_BROKER_DEFAULT_PRESET=standard
SNXMCP_AGENT_BROKER_DEFAULT_ALLOWED_SYMBOLS=
SNXMCP_AGENT_BROKER_DEFAULT_ALLOWED_ORDER_TYPES=LIMIT,MARKET
SNXMCP_AGENT_BROKER_DEFAULT_MAX_ORDER_QUANTITY=
SNXMCP_AGENT_BROKER_DEFAULT_MAX_POSITION_QUANTITY=
SNXMCP_AGENT_BROKER_ALLOW_NON_LOOPBACK=false

SNXMCP_HTTP_IDLE_TIMEOUT=120s
SNXMCP_HTTP_READ_HEADER_TIMEOUT=10s
SNXMCP_SHUTDOWN_TIMEOUT=10s

# Host-run `go run`: listen here. In root compose.yml, MCP metrics are published as 9089:9090.
SNXMCP_METRICS_PORT=9096
SNXMCP_METRICS_PPROF_ENABLED=true
SNXMCP_METRICS_BLOCK_PROFILE_RATE=1
SNXMCP_METRICS_MUTEX_PROFILE_FRACTION=1
